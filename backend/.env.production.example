# =============================================================================
# Render setup (FREE TIER — no Shell / Premium required)
# =============================================================================
#
# 1. Render Dashboard → your Web Service → Settings
#    Build Command:  ./build.sh
#    Start Command:  gunicorn config.wsgi
#
# 2. Render Dashboard → Environment → add the variables below
#
# 3. Click "Manual Deploy" → Deploy latest commit
#    Admin user is created automatically during build (ensure_admin).
#
# 4. Log in on Vercel admin page with ADMIN_USERNAME / ADMIN_PASSWORD
#
# To reset admin password later (still no Shell):
#   Set ADMIN_RESET_PASSWORD=true, redeploy, then set it back to false.
# =============================================================================

DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret

ALLOWED_HOSTS=.onrender.com,smart-certificate-management-and.onrender.com

FRONTEND_BASE_URL=https://your-app.vercel.app

# Creates admin on first deploy (no Shell needed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
# ADMIN_EMAIL=admin@example.com

# Set to true only when you need to reset the password above, then redeploy once
# ADMIN_RESET_PASSWORD=true

# DATABASE_URL is usually set automatically if you linked a database on Render
